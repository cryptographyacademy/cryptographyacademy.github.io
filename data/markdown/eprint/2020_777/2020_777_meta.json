  "debug_data_path": "debug_data/2020_777",
  "eprint": {
    "title": "Dynamic Universal Accumulator with Batch Update over Bilinear Groups",
    "authors": [
      {
        "name": "Giuseppe Vitto",
        "email": "vitto@uni",
        "affiliation": ""
      },
      {
        "name": "Alex Biryukov",
        "email": "biryukov@uni",
        "affiliation": ""
      }
    ],
    "abstract": "We propose a Dynamic Universal Accumulator in the Accumulator Manager setting for bilinear groups which extends Nguyen's positive accumulator and Au et al. and Damgård and Triandopoulos non-membership proof mechanism. The new features include support for batch addition and deletion operations as well as a privacy-friendly decentralized batch witness update protocol, where the witness update information is the same for all users. Together with a non-interactive zero-knowledge protocol, these make the proposed scheme suitable as an efficient and scalable Anonymous Credential System, accessible even by low-resource users.\nWe show security of the proposed protocol in the Generic Group Model under a (new) generalized version of the t-SDH assumption and we demonstrate its practical relevance by providing and discussing an implementation  realized using state-of-the-art libraries.",
    "keywords": [
      "accumulator",
      "universal",
      "dynamic",
      "batch update",
      "privacy-preserving KYC",
      "anonymous credentials"
    ],
    "category": "Cryptographic protocols",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2021-09-13",
    "license": "CC BY",
    "related_papers": []
  }
