  "eprint": {
    "title": "Dynamic Decentralized Functional Encryption",
    "authors": [
      {
        "name": "Jérémy Chotard",
        "email": "dufoursans@gmail",
        "affiliation": ""
      },
      {
        "name": "Edouard Dufour-Sans",
        "email": "rgay@gmail",
        "affiliation": ""
      },
      {
        "name": "Romain Gay",
        "email": "pointcheval@ens",
        "affiliation": ""
      },
      {
        "name": "Duong Hieu Phan",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "David Pointcheval",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "We introduce Dynamic Decentralized Functional Encryption (DDFE), a generalization of Functional Encryption which allows multiple users to join the system dynamically, without relying on a trusted third party or on expensive and interactive Multi-Party Computation protocols.\nThis notion subsumes existing multi-user extensions of Functional Encryption, such as Multi-Input, Multi-Client, and Ad Hoc Multi-Input Functional Encryption.\nWe define and construct schemes for various functionalities which serve as building-blocks for latter primitives and may be useful in their own right, such as a scheme for dynamically computing sums in any Abelian group. These constructions build upon simple primitives in a modular way, and have instantiations from well-studied assumptions, such as DDH or LWE.\nOur constructions culminate in an Inner-Product scheme for computing weighted sums on aggregated encrypted data, from standard assumptions in prime-order groups in the Random Oracle Model.",
    "keywords": [
      "Dynamic",
      "Decentralized",
      "Functional Encryption",
      "Inner Product."
    ],
    "category": "Public-key cryptography",
    "publication_info": "A minor revision of an IACR publication in CRYPTO 2020",
    "last_updated": "2020-09-06",
    "license": "CC BY",
    "related_papers": []
  }
