  "debug_data_path": "debug_data/2017_139",
  "eprint": {
    "title": "Revisiting AES Related-Key Differential Attacks with Constraint Programming",
    "authors": [
      {
        "name": "David Gérault",
        "email": "minier@loria",
        "affiliation": ""
      },
      {
        "name": "Pascal Lafourcade",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Marine Minier",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Christine Solnon",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "The Advanced Encryption Standard (AES) is one of the\nmost studied symmetric encryption schemes. During the last years,\nseveral attacks have been discovered in different adversary models. In\nthis paper, we focus on related-key differential attacks, where the\nadversary may introduce differences in plaintext pairs and also in\nkeys. We show that Constraint Programming (CP) can be used to model\nthese attacks, and that it allows us to efficiently find all optimal\nrelated-key differential characteristics for AES-128, AES-192 and\nAES-256. In particular, we improve the best related-key differential for the whole AES-256 and give the best related-key differential on 10 rounds of AES-192, which is the differential trail with the longest path. Those results allow us to improve existing related-key distinguishers, basic related-key attacks and $q$-multicollisions on AES-256.",
    "keywords": [
      "AES",
      "Constraint Programming",
      "Related Key differential"
    ],
    "category": "Secret-key cryptography",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2018-07-02",
    "license": "CC BY",
    "related_papers": []
  }
