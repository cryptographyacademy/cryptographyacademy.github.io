  "eprint": {
    "title": "Algorithmic Acceleration of B/FV-like Somewhat Homomorphic Encryption for Compute-Enabled RAM",
    "authors": [
      {
        "name": "Jonathan Takeshita",
        "email": "tjung@nd",
        "affiliation": ""
      },
      {
        "name": "Dayane Reis",
        "email": "edujtakeshi@nd",
        "affiliation": ""
