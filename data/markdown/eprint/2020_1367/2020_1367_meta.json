  "debug_data_path": "debug_data/2020_1367",
  "eprint": {
    "title": "Costs of an Attack Against Proof-of-Work",
    "authors": [
      {
        "name": "Loïc Etienne",
        "email": "etienne@pwc",
        "affiliation": ""
      }
    ],
    "abstract": "Bitcoin is a blockchain whose immutability relies on Proof-of-Work: Before\nappending a new block, some so-called miner has to solve a cryptographic\nchallenge by brute force. The blockchain is spread over a network of faithful\nminers, whose cumulated computing power is assumed to be so large that, among\nother things, it should be too expensive for an attacker to mine a secret fork\n$n$ blocks longer than the main blockchain, provided that $n$ is big enough.\nFor a given targeted advance of $n$ blocks, we investigate the expected time\nfor the attacker to mine such a secret fork, the underlying cumulative\ndistribution function, and some related optimization problems.",
    "keywords": [
      "Bitcoin",
      "Blockchain",
      "Proof-of-Work",
      "Double-spending"
    ],
    "category": "Cryptographic protocols",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-11-02",
    "license": "CC BY",
    "related_papers": []
  }
