  "debug_data_path": "debug_data/2020_906",
  "eprint": {
    "title": "Optimally-resilient Unconditionally-secure Asynchronous Multi-party Computation Revisited",
    "authors": [
      {
        "name": "Ashish Choudhury",
        "email": "choudhury@iiitb",
        "affiliation": ""
      }
    ],
    "abstract": "In this paper, we present an optimally-resilient, unconditionally-secure asynchronous multi-party computation (AMPC)\nprotocol for $n$ parties, tolerating a computationally unbounded adversary, capable of corrupting up to $t < \\frac{n}{3}$ parties. Our protocol needs a communication of ${\\cal O}(n^4)$ field elements per multiplication gate. This is to be compared with previous best AMPC protocol (Patra et al, ICITS 2009) in the same setting, which needs a communication of ${\\cal O}(n^5)$ field elements per multiplication gate. To design our protocol, we present a simple and highly efficient asynchronous verifiable secret-sharing (AVSS) protocol, which is of independent interest.",
    "keywords": [
      "Byzantine faults",
      "secret-sharing",
      "unconditional-security",
      "privacy"
    ],
    "category": "Cryptographic protocols",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-07-19",
