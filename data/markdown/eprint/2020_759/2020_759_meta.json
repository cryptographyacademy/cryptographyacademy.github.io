  "eprint": {
    "title": "Chosen Ciphertext Security from Injective Trapdoor Functions",
    "authors": [
      {
        "name": "Susan Hohenberger",
        "email": "susan@cs",
        "affiliation": ""
      },
      {
        "name": "Venkata Koppula",
        "email": "koppula@weizmann",
        "affiliation": ""
      },
      {
        "name": "Brent Waters",
        "email": "ilbwaters@cs",
        "affiliation": ""
      }
    ],
    "abstract": "We provide a construction of chosen ciphertext secure public-key encryption from (injective) trapdoor functions. Our construction is black box and assumes no special properties (e.g. ``lossy'', ``correlated product secure'') of the trapdoor function.",
    "keywords": [
      "public-key cryptography",
      "CCA security",
      "trapdoor functions"
    ],
    "category": "Foundations",
    "publication_info": "Published by the IACR in CRYPTO 2020",
