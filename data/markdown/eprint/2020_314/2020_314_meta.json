  "debug_data_path": "debug_data/2020_314",
  "eprint": {
    "title": "Proposal of Multivariate Public Key Cryptosystem Based on Modulus of Numerous Prime Numbers and CRT with Security of IND-CPA",
    "authors": [
      {
        "name": "Shigeo Tsujii",
        "email": "tsujii@tamacc",
        "affiliation": ""
      },
      {
        "name": "Ryo Fujita",
        "email": "jprfujita@tamacc",
        "affiliation": ""
      },
      {
        "name": "Masahito Gotaishi",
        "email": "jpgotaishi@tamacc",
        "affiliation": ""
      }
    ],
    "abstract": "We have proposed before a multivariate public key cryptosystem (MPKC) that does not rely on the difficulty of prime factorization, and whose modulus is the product of many small prime numbers. In this system, the prime factorization by the\nattackers is self-trivial, and the structure of the secret key is based on CRT (Chinese Remainder Theorem). In this paper we propose MPKC with security of IND-CPA by adding random numbers to central transformation vectors in the system proposed\nbefore.",
    "keywords": [
      "Post-quantum Cryptography",
      "Multivariate Public Key Cryptosystem",
      "Chinese Remainder Theorem",
      "IND-CPA"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-03-15",
    "license": "CC BY",
    "related_papers": []
  }
