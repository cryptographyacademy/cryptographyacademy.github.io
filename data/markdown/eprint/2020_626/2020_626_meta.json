  "debug_data_path": "debug_data/2020_626",
  "eprint": {
    "title": "Game theoretical framework for analyzing Blockchains Robustness",
    "authors": [
      {
        "name": "Paolo Zappalà",
        "email": "potop-butucaru@lip6",
        "affiliation": ""
      },
      {
        "name": "Marianna Belotti",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Maria Potop-Butucaru",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Stefano Secci",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "Blockchains systems evolve in complex environments that mix classical patterns of faults\n(e.g crash faults, transient faults, Byzantine faults, churn) with selfish, rational or irrational behaviors\ntypical to economical systems. In this paper we propose a game theoretical framework\nin order to formally characterize the robustness of blockchains systems in terms of resilience to\nrational deviations and immunity to Byzantine behaviors. Our framework includes necessary\nand sufficient conditions for checking the immunity and resilience of games and a new technique\nfor composing games that preserves the robustness of individual games. We prove the\npractical interest of our formal framework by characterizing the robustness of three different\nprotocols popular in blockchain systems: a HTLC-based payment scheme (a.k.a. Lightning\nNetwork), a side-chain protocol and a cross-chain swap protocol.",
    "keywords": [
      "game theory",
      "robustness",
      "blockchains"
    ],
    "category": "Foundations",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-06-03",
    "license": "CC BY",
    "related_papers": []
  }
