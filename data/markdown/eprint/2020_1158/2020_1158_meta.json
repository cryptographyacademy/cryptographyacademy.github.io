  "debug_data_path": "debug_data/2020_1158",
  "eprint": {
    "title": "Don't throw your nonces out with the bathwater: Speeding up Dilithium by reusing the tail of y",
    "authors": [
      {
        "name": "Amber Sprenkels",
        "email": "amber@electricdusk",
        "affiliation": ""
      },
      {
        "name": "Bas Westerbaan",
        "email": "combas@westerbaan",
        "affiliation": ""
      }
    ],
    "abstract": "We suggest a small change to the Dilithium signature scheme, that allows one to reuse computations between rejected nonces, for a speed-up in signing time.\r\nThe modification is based on the idea that, after rejecting on a too large $\\|\\mathbf{r}_0\\|_\\infty$, not all elements of the nonce $\\mathbf{y}$ are spent.\r\nWe swap the order of the checks; and if this $\\mathbf{r}_0$-check fails, we only need to resample $y_1$.\r\nWe provide a proof that shows that the modification does not affect the security of the scheme.\r\nWe present measurements of the performance of the modified scheme on AVX2, Cortex M4, and Cortex M3,\r\nwhich show a speed-up ranging from 11% for Dilithium2 on M3 to 22% for Dilithium3 on AVX2.",
    "keywords": [
      "Dilithium",
      "Fiat-Shamir with aborts",
      "lattice-based cryptography",
      "AVX2",
      "ARM Cortex-M4",
      "ARM Cortex-M3"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Preprint.",
    "last_updated": "2023-05-24",
    "license": "CC BY",
    "related_papers": []
  }
