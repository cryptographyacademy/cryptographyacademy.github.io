  "eprint": {
    "title": "Efficient Quantum Public-Key Encryption From Learning With Errors",
    "authors": [
      {
        "name": "Javad Doliskani",
        "email": "doliskani@ryerson",
        "affiliation": ""
      }
    ],
    "abstract": "Our main result is a quantum public-key encryption scheme based on the Extrapolated Di-\nhedral Coset problem (EDCP) which is equivalent, under quantum polynomial-time reductions,\nto the Learning With Errors (LWE) problem. For limited number of public keys (roughly linear\nin the security parameter), the proposed scheme is information-theoretically secure. For poly-\nnomial number of public keys, breaking the scheme is as hard as solving the LWE problem.\nThe public keys in our scheme are quantum states of size Õ(n) qubits. The key generation and\ndecryption algorithms require Õ(n) qubit operations while the encryption algorithm takes O(1)\nqubit operations.",
    "keywords": [
      "Quantum Cryptography",
      "Public-Key Encryption",
      "Learning With Errors",
      "Dihedral Coset"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-12-14",
