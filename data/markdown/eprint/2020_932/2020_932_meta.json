  "eprint": {
    "title": "A Note on Authenticated Group Key Agreement Protocol Based on Twist Conjugacy Problem in Near – Rings",
    "authors": [
      {
        "name": "Atul Chaturvedi",
        "email": "atulibs@gmail",
        "affiliation": ""
