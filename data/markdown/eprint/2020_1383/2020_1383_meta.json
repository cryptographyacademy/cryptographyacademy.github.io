  "eprint": {
    "title": "Novel Single-Trace ML Profiling Attacks on NIST 3 Round candidate Dilithium",
    "authors": [
      {
        "name": "Il-Ju Kim",
        "email": "kimij2905@kookmin",
        "affiliation": ""
      },
      {
        "name": "Tae-Ho Lee",
        "email": "",
