  "eprint": {
    "title": "Foxtail+: A Learning with Errors-based Authentication Protocol for Resource-Constrained Devices",
    "authors": [
      {
        "name": "Matthieu Monteiro",
        "email": "jameel@gmail",
        "affiliation": ""
