  "eprint": {
    "title": "A modern signature scheme with message recovery: Abe--Okamoto signatures with EdDSA elements",
    "authors": [
      {
        "name": "Satō Shinichi",
        "email": "sato@airmail",
        "affiliation": ""
      }
    ],
    "abstract": "This paper revisits the Abe--Okamoto signature scheme to present a version of their signature scheme augmented with modern best practices, with major influences taken from EdDSA. Implementation guidance is given on how to reuse existing Ed25519 code.",
    "keywords": [
      "digital signatures"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-04-19",
    "license": "CC BY",
    "related_papers": []
  }
