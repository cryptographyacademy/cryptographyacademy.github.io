  "eprint": {
    "title": "iToken: One-Time-Use Anonymous Token with Issuance Hiding",
    "authors": [
      {
        "name": "Zengpeng Li",
        "email": "zengpengliz@gmail",
        "affiliation": ""
      },
      {
        "name": "Xiangyu Su",
