  "eprint": {
    "title": "FLiPD: Privacy-Preserving Federated Learning via Multi-Party Computation and Differential Privacy",
    "authors": [
      {
        "name": "Gowri R Chandran",
        "email": "gowri@simula",
        "affiliation": ""
      },
      {
        "name": "Melek Önen",
