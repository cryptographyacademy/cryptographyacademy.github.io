  "eprint": {
    "title": "Spinel: A Post-Quantum Signature Scheme Based on $\\mathrm{SL}_n(\\mathbb{F}_p)$ Hashing",
    "authors": [
      {
        "name": "Asmaa Cherkaoui",
        "email": "esma1maysan@gmail",
        "affiliation": ""
      },
      {
        "name": "Faraz Heravi",
        "email": "comfarazh@utexas",
        "affiliation": ""
