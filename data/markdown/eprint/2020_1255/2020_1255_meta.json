  "eprint": {
    "title": "Boolean Ring Cryptographic Equation Solving",
    "authors": [
      {
        "name": "Sean Murphy",
        "email": "murphy@rhul",
        "affiliation": ""
      },
      {
        "name": "Maura Paterson",
        "email": "",
