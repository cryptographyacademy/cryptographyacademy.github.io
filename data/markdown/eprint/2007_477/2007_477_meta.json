  "debug_data_path": "debug_data/2007_477",
  "eprint": {
    "title": "Algebraic Side-Channel Collision Attacks on AES",
    "authors": [
      {
        "name": "Andrey Bogdanov",
        "email": "abogdanov@crypto",
        "affiliation": ""
      },
      {
        "name": "Andrey Pyshkin",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "This paper presents a new powerful side-channel cryptanalytic method - algebraic collision attacks - representing an efficient class of power analysis being based on both the power consumption information leakage and specific structure of the attacked cryptographic algorithm. This can result in an extremely low measurement count needed for a key recovery.\n\nThe algebraic collision attacks are well applicable to AES, if one-byte collisions are detectable. For the recovery of the complete AES key, one needs 3 measurements with a probability of 0.42 and 4.24 PC hours post-processing, 4 measurements with a probability of 0.82 and several seconds of offline computations or 5 measurements with success probability close to 1 and several seconds of post-processing.",
    "keywords": [
      "AES",
      "collision attacks",
      "side-channel attacks",
      "generalized collisions",
      "Groebner bases",
      "algebraic attacks",
      "F4 algorithm"
    ],
    "category": "Secret-key cryptography",
    "publication_info": "Published elsewhere. Unknown where it was published",
    "last_updated": "2007-12-28",
    "license": "CC BY",
    "related_papers": []
  }
