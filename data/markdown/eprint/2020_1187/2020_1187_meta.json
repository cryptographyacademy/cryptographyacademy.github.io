  "eprint": {
    "title": "Coupling of Random Systems",
    "authors": [
      {
        "name": "David Lanzenberger",
        "email": "landavid@inf",
        "affiliation": ""
      },
      {
        "name": "Ueli Maurer",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "This paper makes three contributions. First, we present a simple theory of\nrandom systems. The main idea is to think of a probabilistic system as an\nequivalence class of distributions over deterministic systems. Second, we\ndemonstrate how in this new theory, the optimal\ninformation-theoretic distinguishing advantage between two systems can be\ncharacterized merely in terms of the statistical distance of probability\ndistributions, providing a more elementary understanding of the distance of\nsystems. In particular, two systems that are $\\epsilon$-close in terms of the\nbest distinguishing advantage can be understood as being equal with\nprobability 1-$\\epsilon$, a property that holds statically, without even\nconsidering a distinguisher, let alone its interaction with the systems.\nFinally, we exploit this new characterization of the distinguishing advantage\nto prove that any threshold combiner is an amplifier for indistinguishability\nin the information-theoretic setting, generalizing and simplifying results\nfrom Maurer, Pietrzak, and Renner (CRYPTO 2007).",
    "keywords": [
      "random systems",
      "coupling",
      "coupling lemma",
      "information-theoretic indistinguishability",
      "indistinguishability amplification"
    ],
    "category": "Foundations",
    "publication_info": "A minor revision of an IACR publication in TCC 2020",
    "last_updated": "2021-06-14",
    "license": "CC BY",
    "related_papers": []
  }
