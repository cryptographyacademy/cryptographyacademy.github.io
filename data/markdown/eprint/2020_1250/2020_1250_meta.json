  "eprint": {
    "title": "A New Code Based Signature Scheme without Trapdoors",
    "authors": [
      {
        "name": "Zhe Li",
        "email": "lzonline01@gmail",
        "affiliation": ""
      },
      {
        "name": "Chaoping Xing",
