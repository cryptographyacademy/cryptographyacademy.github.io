  "eprint": {
    "title": "Post-Quantum Adaptor Signatures with Strong Security from Cryptographic Group Actions",
    "authors": [
      {
        "name": "Ryann Cartor",
        "email": "rcartor@clemson",
        "affiliation": ""
      },
      {
        "name": "Nathan Daly",
        "email": "edundaly@vt",
        "affiliation": ""
      },
      {
        "name": "Giulia Gaggero",
        "email": "edugaggerog@mcmaster",
        "affiliation": ""
      },
      {
        "name": "Jason T. LeGrow",
        "email": "cajlegrow@vt",
        "affiliation": ""
      },
      {
        "name": "Andrea Sanguineti",
        "email": "sanguineti@gmail",
        "affiliation": ""
      },
      {
        "name": "Silvia Sconza",
        "email": "sconza@math",
        "affiliation": ""
      }
    ],
    "abstract": "We present One Round \"Cheating\" Adaptor Signatures (OR-\r\nCAS): a novel and eﬀicient construction of adaptor signature schemes\r\nfrom CSI-FiSh. Our protocol improves substantially on existing group\r\naction-based schemes: Unlike IAS (Tairi et al., FC 2021), our scheme\r\ndoes not require expensive non-interactive zero-knowledge proofs, and\r\nunlike adaptor MCSI-FiSh (Jana et al., CANS 2024) our construction\r\ndoes not require any modification to the underlying digital signature\r\nscheme. We prove the protocol’s security under the strong security no-\r\ntions of Dai et al. (Indocrypt 2022) and Gerhart et al. (Eurocrypt 2024).",
    "keywords": [
      "Post-quantum cryptography",
      "Adaptor signatures",
      "Digital signatures",
      "Public-key cryptography"
    ],
    "category": "Cryptographic protocols",
    "publication_info": "Published elsewhere. PQCrypto 2026",
    "last_updated": "2026-02-24",
