  "debug_data_path": "debug_data/2026_314",
  "eprint": {
    "title": "Understanding Multi-Query Attacks on Key-Then-Hash Functions",
    "authors": [
      {
        "name": "Jonathan Fuchs",
        "email": "fuchs@ru",
        "affiliation": ""
      }
    ],
    "abstract": "We present multi-query attacks on key-then-hash (KTH) functions in the blinded keyed hash model that achieve an advantage growing quadratically in the number of queries up to a small constant factor from the information-theoretic upper bound.\r\nWe introduce three families of attacks.\r\nCatch attacks exploit the group structure of the digest space and achieve deterministic success with $2\\sqrt{\\varepsilon^{-1}}$ queries.\r\nGroup attacks embed high-probability differentials into subgroups of the message space of quadratic advantage.\r\nTranslation attacks exploit offset-invariance to linearly scale any existing attack.\r\nOur attacks apply in two concrete settings: with $\\Delta$ fixed to $0$, they target the compression phase of farfalle-based primitives such as Xoofff, and with $\\Delta$ as a free parameter, they target deck-based wide block cipher constructions such as the double-decker.\r\nWe connect optimal query set construction to results in additive combinatorics and generalize our results to concatenated KTH functions.\r\nExperiments on NH and Xoodoo[3] show our attacks reach an advantage within a factor $2^{4}$ of the theoretical bound.\r\nOur analysis reveals that for bit-sliced permutations with degree-2 round functions, solution set overlap is inherent, limiting but not preventing the attacker from approaching the bound. Our experiments highlight that trail cores with a large number of active columns in the last round are particularly dangerous for KTH functions, introducing a new criterion for the design of permutations used in such constructions.",
    "keywords": [
      "message authentication codes",
      "key-then-hash",
      "multi-query security",
      "offset-invariance",
      "protected hash",
      "blinded keyed hash"
    ],
    "category": "Secret-key cryptography",
    "publication_info": "Preprint.",
    "last_updated": "2026-02-21",
    "license": "CC BY",
    "related_papers": []
  }
