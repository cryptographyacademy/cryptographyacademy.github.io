  "eprint": {
    "title": "FPL: White-Box Secure Block Cipher Using Parallel Table Look-Ups",
    "authors": [
      {
        "name": "Jihoon Kwon",
        "email": "hicalf@gmail",
        "affiliation": ""
      },
      {
        "name": "Byeonghak Lee",
        "email": "",
        "affiliation": ""
