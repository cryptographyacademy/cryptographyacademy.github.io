  "eprint": {
    "title": "Security of the Fiat-Shamir Transformation in the Quantum Random-Oracle Model",
    "authors": [
      {
        "name": "Jelle Don",
        "email": "don@cwi",
        "affiliation": ""
      },
      {
        "name": "Serge Fehr",
