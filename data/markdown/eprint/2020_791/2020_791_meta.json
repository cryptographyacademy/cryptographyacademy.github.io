  "eprint": {
    "title": "Virtual ASICs: Generalized Proof-of-Stake Mining in Cryptocurrencies",
    "authors": [
      {
        "name": "Chaya Ganesh",
        "email": "chaya@iisc",
        "affiliation": ""
