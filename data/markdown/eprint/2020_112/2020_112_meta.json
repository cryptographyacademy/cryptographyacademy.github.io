  "debug_data_path": "debug_data/2020_112",
  "eprint": {
    "title": "A Detailed Report on the Overhead of Hardware APIs for Lightweight Cryptography",
    "authors": [
      {
        "name": "Patrick Karl",
        "email": "karl@tum",
        "affiliation": ""
      },
      {
        "name": "Michael Tempelmeier",
        "email": "tempelmeier@tum",
        "affiliation": ""
      }
    ],
    "abstract": "The \"Competition for Authenticated Encryption: Security, Applicability, and Robustness\" (CAESAR) was the first cryptographic\ncompetition that required designers to use a mandatory hardware API for their implementations.\nRecently, a similar hardware API for the NIST Lightweight Cryptography (LWC) project was proposed.\nBoth APIs feature an accompanying development package to help designers implementing the API.\n\nIn this paper, we have an in-depth look on these packages.\nWe analyze the features of both packages, discuss their resource utilization, and\ndemonstrate their impact on Ascon128, SpoC-64, and Gimli implementations on a modern Artix-7 FPGA.\nFinally, we provide some tweaks and enhancements to further optimize the development package for the LWC API.",
    "keywords": [
      "LWC",
      "CAESAR",
      "API",
      "FPGA",
      "Gimli",
      "Ascon",
      "SpoC",
      "lightweight cryptography",
      "AEAD",
      "Authenticated Encryption"
    ],
    "category": "Implementation",
    "publication_info": "Preprint. MINOR revision.",
