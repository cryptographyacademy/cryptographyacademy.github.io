  "eprint": {
    "title": "Raccoon Attack: Finding and Exploiting Most-Significant-Bit-Oracles in TLS-DH(E)",
    "authors": [
      {
        "name": "Robert Merget",
        "email": "brinkmann@rub",
        "affiliation": ""
      },
      {
        "name": "Marcus Brinkmann",
        "email": "merget@rub",
        "affiliation": ""
      },
      {
        "name": "Nimrod Aviram",
        "email": "aviram@gmail",
        "affiliation": ""
