  "eprint": {
    "title": "Making the BKW Algorithm Practical for LWE",
    "authors": [
      {
        "name": "Alessandro Budroni",
        "email": "budroni@uib",
        "affiliation": ""
      },
      {
        "name": "Qian Guo",
        "email": "alessandro@gmail",
