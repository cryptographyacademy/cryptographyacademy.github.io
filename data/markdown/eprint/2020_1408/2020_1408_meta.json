  "eprint": {
    "title": "On Broadcast in Generalized Network and Adversarial Models",
    "authors": [
      {
        "name": "Chen-Da Liu-Zhang",
        "email": "lichen@inf",
        "affiliation": ""
      },
      {
        "name": "Varun Maram",
