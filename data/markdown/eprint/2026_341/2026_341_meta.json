  "eprint": {
    "title": "Syndrome Decoding with Hints",
    "authors": [
      {
        "name": "Letizia D'Achille",
        "email": "dachille@rub",
        "affiliation": ""
      },
      {
        "name": "Andre Esser",
        "email": "esser@gmail",
