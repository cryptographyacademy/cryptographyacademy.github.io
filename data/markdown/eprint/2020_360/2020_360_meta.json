  "eprint": {
    "title": "Composite Algorithm The New Algorithm to Search for Monic Irreducible Polynomials over Extended Galois Fields",
    "authors": [
      {
        "name": "Sankhanil Dey",
        "email": "sdrpe_rs@caluniv",
