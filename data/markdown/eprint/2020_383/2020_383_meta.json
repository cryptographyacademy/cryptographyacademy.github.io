  "debug_data_path": "debug_data/2020_383",
  "eprint": {
    "title": "Parallel strategies for SIDH: Towards computing SIDH twice as fast",
    "authors": [
      {
        "name": "Daniel Cervantes-Vázquez",
        "email": "dcervantes@computacion",
        "affiliation": ""
      },
      {
        "name": "Eduardo Ochoa-Jiménez",
        "email": "mxfrancisco@cs",
        "affiliation": ""
      },
      {
        "name": "Francisco Rodríguez-Henríquez",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "We present novel strategies and concrete algorithms for the parallel computation\nof the Supersingular Isogeny-based Diffie-Hellman key exchange (SIDH) protocol\nwhen executed on multi-core platforms. The most relevant design idea exploited\nby our approach is that of concurrently computing scalar multiplication operations\nalong with a parallelized version of the strategies required for constructing and\nevaluating large smooth degree isogenies. We report experimental results showing\nthat a three-core implementation of our parallel approach achieves an acceleration\nfactor of 1.56 compared against a sequential implementation of the SIKE protocol.",
    "keywords": [
      "Isogeny-based cryptography",
      "post-quantum cryptography",
      "Isogeny",
      "Isogenies",
      "Parallel Computing",
      "SIKE"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-04-07",
    "license": "CC BY",
    "related_papers": []
  }
