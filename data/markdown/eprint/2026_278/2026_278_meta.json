  "eprint": {
    "title": "Exploiting PDF Obfuscation in LLMs, arXiv, and More",
    "authors": [
      {
        "name": "Zhongtang Luo",
        "email": "luo401@purdue",
        "affiliation": ""
      },
      {
        "name": "Jianting Zhang",
        "email": "eduzhan4674@purdue",
