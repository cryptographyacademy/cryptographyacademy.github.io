  "eprint": {
    "title": "Optimizing Inner Product Masking Scheme by A Coding Theory Approach",
    "authors": [
      {
        "name": "Wei Cheng",
        "email": "cheng@telecom-paris",
        "affiliation": ""
      },
      {
        "name": "Sylvain Guilley",
        "email": "",
