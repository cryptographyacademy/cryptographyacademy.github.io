  "debug_data_path": "debug_data/2020_1191",
  "eprint": {
    "title": "Schrödinger's Pirate: How To Trace a Quantum Decoder",
    "authors": [
      {
        "name": "Mark Zhandry",
        "email": "mzhandry@gmail",
        "affiliation": ""
      }
    ],
    "abstract": "We explore the problem of traitor tracing where the pirate decoder can contain a quantum state. Our main results include:\n- We show how to overcome numerous definitional challenges to give a meaningful notion of tracing for quantum decoders\n- We give negative results, demonstrating barriers to adapting classical tracing algorithms to the quantum decoder setting.\n- On the other hand, we show how to trace quantum decoders in the setting of (public key) private linear broadcast encryption, capturing a common approach to traitor tracing.",
    "keywords": [
      "Quantum",
      "Traitor Tracing"
    ],
    "category": "Foundations",
    "publication_info": "A minor revision of an IACR publication in TCC 2020",
    "last_updated": "2020-09-30",
    "license": "CC BY",
    "related_papers": []
  }
}
