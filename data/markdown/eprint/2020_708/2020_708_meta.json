  "eprint": {
    "title": "Lamphone: Real-Time Passive Sound Recovery from Light Bulb Vibrations",
    "authors": [
      {
        "name": "Ben Nassi",
        "email": "nassiben5@gmail",
        "affiliation": ""
      },
