  "eprint": {
    "title": "Round-Efficient Byzantine Broadcast under Strongly Adaptive and Majority Corruptions",
    "authors": [
      {
        "name": "Jun Wan",
        "email": "junwan@mit",
        "affiliation": ""
      },
      {
        "name": "Hanshen Xiao",
        "email": "eduhanshen@mit",
