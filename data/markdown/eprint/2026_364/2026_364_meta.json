  "eprint": {
    "title": "SPRINT: New Isogeny Proofs of Knowledge and Isogeny-Based Signatures",
    "authors": [
      {
        "name": "Thomas den Hollander",
        "email": "thomasdh@unibw",
        "affiliation": ""
