  "eprint": {
    "title": "Bitcoin Crypto–Bounties for Quantum Capable Adversaries",
    "authors": [
      {
        "name": "Dragos Ioan Ilie",
        "email": "dii14@ic",
        "affiliation": ""
      },
      {
        "name": "Kostis Karantias",
