  "eprint": {
    "title": "An Analytic Attack Against ARX Addition Exploiting Standard Side-Channel Leakage",
    "authors": [
      {
        "name": "Yan Yan",
        "email": "yanyansmajesty@gmail",
        "affiliation": ""
      },
      {
        "name": "Elisabeth Oswald",
        "email": "",
