  "eprint": {
    "title": "An Efficient Authenticated Key Exchange from Random Self-Reducibility on CSIDH",
    "authors": [
      {
        "name": "Tomoki Kawashima",
        "email": "tomoki_kawashima@mist",
        "affiliation": ""
