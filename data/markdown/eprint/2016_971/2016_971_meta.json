  "eprint": {
    "title": "Authenticated communication from Quantum Readout of PUFs",
    "authors": [
      {
        "name": "B.  Skoric",
        "email": "skoric@tue",
        "affiliation": ""
      },
      {
        "name": "P. W. H.  Pinkse",
