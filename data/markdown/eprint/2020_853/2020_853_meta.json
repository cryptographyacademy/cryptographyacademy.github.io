  "eprint": {
    "title": "Linear-Complexity Private Function Evaluation is Practical",
    "authors": [
      {
        "name": "Marco Holz",
        "email": "kiss@encrypto",
        "affiliation": ""
      },
      {
        "name": "Ágnes Kiss",
