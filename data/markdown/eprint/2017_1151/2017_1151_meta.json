  "eprint": {
    "title": "Shorter Linear Straight-Line Programs for MDS Matrices",
    "authors": [
      {
        "name": "Thorsten Kranz",
        "email": "kranz@rub",
        "affiliation": ""
      },
      {
        "name": "Gregor Leander",
