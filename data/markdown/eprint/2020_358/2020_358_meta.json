  "eprint": {
    "title": "Division Algorithm to search for monic irreducible polynomials over extended Galois Field GF(p^q).",
    "authors": [
      {
        "name": "Sankhanil Dey",
        "email": "sdrpe_rs@caluniv",
        "affiliation": ""
