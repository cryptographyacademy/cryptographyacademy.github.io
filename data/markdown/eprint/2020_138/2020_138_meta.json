  "eprint": {
    "title": "Smart Contract Derivatives",
    "authors": [
      {
        "name": "Kostis Karantias",
        "email": "kkarantias@gmail",
        "affiliation": ""
      },
      {
        "name": "Aggelos Kiayias",
        "email": "comdionyziz@gmail",
        "affiliation": ""
