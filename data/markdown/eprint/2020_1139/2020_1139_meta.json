  "debug_data_path": "debug_data/2020_1139",
  "eprint": {
    "title": "Succinct and Adaptively Secure ABE for ABP from k-Lin",
    "authors": [
      {
        "name": "Huijia Lin",
        "email": "rachel@cs",
        "affiliation": ""
      },
      {
        "name": "Ji Luo",
        "email": "eduluoji@cs",
        "affiliation": ""
      }
    ],
    "abstract": "We present *succinct* and *adaptively secure* attribute-based encryption (ABE)\nschemes for *arithmetic branching programs*, based on k-Lin in pairing groups.\nOur key-policy ABE scheme has ciphertexts of *constant size*, independent of\nthe length of the attributes, and our ciphertext-policy ABE scheme has secret\nkeys of *constant size*.  Our schemes improve upon the recent succinct ABE\nschemes in [Attrapadung and Tomida, Asiacrypt '20], which only handle Boolean\nformulae.  All other prior succinct ABE schemes either achieve only selective\nsecurity or rely on $q$-type assumptions.\n\nOur schemes are obtained through a general and modular approach that combines\na public-key inner-product functional encryption satisfying a new security\nnotion called gradual simulation security and an information-theoretic\nrandomized encoding scheme called arithmetic key garbling scheme.",
    "keywords": [],
    "category": "Public-key cryptography",
    "publication_info": "A major revision of an IACR publication in ASIACRYPT 2020",
    "last_updated": "2022-03-16",
    "license": "CC BY",
    "related_papers": []
  }
