  "eprint": {
    "title": "Magnifying Side-Channel Leakage of Lattice-Based Cryptosystems with Chosen Ciphertexts: The Case Study of Kyber",
    "authors": [
      {
        "name": "Zhuang Xu",
        "email": "xu_zhuang@buaa",
