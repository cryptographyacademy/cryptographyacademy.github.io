  "debug_data_path": "debug_data/2026_329",
  "eprint": {
    "title": "Oblivious Ciphertext Compression via Linear Codes",
    "authors": [
      {
        "name": "Pascal Giorgi",
        "email": "giorgi@lirmm",
        "affiliation": ""
      },
      {
        "name": "Bruno Grenet",
        "email": "grenet@univ-grenoble-alpes",
        "affiliation": ""
      },
      {
        "name": "Mark Simkin",
        "email": "frmark@univariate",
        "affiliation": ""
      }
    ],
    "abstract": "Oblivious ciphertext compression and decompression transform encrypted dense vectors of length $n$ with at most $t$ non-zero entries into compact encrypted sparse representations, and vice versa. \r\nThese primitives appear in the context of efficient protocols for encrypted search, PIR, and oblivious message retrieval.\r\nExisting schemes suffer from large ciphertext sizes or high computational cost. \r\nWe present new deterministic and perfectly correct constructions based on linear codes, yielding encrypted sparse representations of optimal size with near-linear compression and decompression times. \r\nOur results improve both communication and computation over prior work.\r\nA central ingredient of our work is to show that, for carefully chosen generalized Reed–Solomon codes, variants of classical decoding algorithms combined with efficient algebraic techniques enable to recover the error vector directly from the syndrome in quasi-linear time in the syndrome length, rather than in the full block length of the code.",
    "keywords": [
      "Ciphertext Compression",
      "Ciphertext Decompression",
      "additively homomorphic encryption"
    ],
    "category": "Foundations",
    "publication_info": "Published by the IACR in EUROCRYPT 2026",
    "last_updated": "2026-02-22",
    "license": "CC BY",
    "related_papers": []
  }
