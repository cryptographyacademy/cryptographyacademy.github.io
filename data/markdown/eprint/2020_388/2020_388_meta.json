  "eprint": {
    "title": "Fast 4 way vectorized ladder for the complete set of Montgomery curves",
    "authors": [
      {
        "name": "Huseyin Hisil",
        "email": "hisil@yasar",
        "affiliation": ""
      },
      {
        "name": "Berkan Egrice",
