  "debug_data_path": "debug_data/2020_859",
  "eprint": {
    "title": "A Classification of Computational Assumptions in the Algebraic Group Model",
    "authors": [
      {
        "name": "Balthazar Bauer",
        "email": "bauer@ens",
        "affiliation": ""
      },
      {
        "name": "Georg Fuchsbauer",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Julian Loss",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "We give a taxonomy of computational assumptions in the algebraic group model (AGM).  We first analyze Boyen's Uber assumption family for bilinear groups and then extend it in several ways to cover assumptions as diverse as Gap Diffie-Hellman and LRSW.  We show that in the AGM every member of these families is implied by the $q$-discrete logarithm (DL) assumption, for some $q$ that depends on the degrees of the polynomials defining the Uber assumption.\n\nUsing the meta-reduction technique, we then separate $(q+1)$-DL from $q$-DL, which yields a classification of all members of the extended Uber-assumption families.  We finally show that there are strong assumptions, such as one-more DL, that provably fall outside our classification, by proving that they cannot be reduced from $q$-DL even in the AGM.",
    "keywords": [
      "Algebraic Group Model",
      "Uber Assumption",
      "Pairing-Based Cryptography"
    ],
    "category": "Foundations",
    "publication_info": "A major revision of an IACR publication in CRYPTO 2020",
    "last_updated": "2020-07-12",
    "license": "CC BY",
    "related_papers": []
  }
