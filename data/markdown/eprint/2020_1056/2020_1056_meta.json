  "eprint": {
    "title": "Automated enumeration of block cipher differentials: An optimized branch-and-bound GPU framework",
    "authors": [
      {
        "name": "Wei-Zhu Yeoh",
        "email": "yeohweizhu@gmail",
        "affiliation": ""
