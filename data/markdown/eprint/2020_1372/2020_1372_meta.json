  "eprint": {
    "title": "VCKSCF: Efficient Verifiable Conjunctive Keyword Search Based on Cuckoo Filter for Cloud Storage",
    "authors": [
      {
        "name": "Chan Fan",
        "email": "51184501009@stu",
        "affiliation": ""
      },
      {
        "name": "Xiaolei Dong",
        "email": "",
