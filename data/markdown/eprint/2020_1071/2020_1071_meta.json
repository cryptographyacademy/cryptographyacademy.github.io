  "eprint": {
    "title": "On Pairing-Free Blind Signature Schemes in the Algebraic Group Model",
    "authors": [
      {
        "name": "Julia Kastner",
        "email": "kastner@inf",
        "affiliation": ""
      },
      {
        "name": "Julian Loss",
        "email": "chlossjulian@gmail",
