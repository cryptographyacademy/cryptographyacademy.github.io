  "eprint": {
    "title": "NTT Multiplication for NTT-unfriendly Rings",
    "authors": [
      {
        "name": "Chi-Ming Marvin Chung",
        "email": "marvin852316497@gmail",
        "affiliation": ""
      },
      {
        "name": "Vincent Hwang",
