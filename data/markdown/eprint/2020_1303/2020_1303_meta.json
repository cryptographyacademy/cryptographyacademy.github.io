  "eprint": {
    "title": "Post-Quantum Cryptography with Contemporary Co-Processors: Beyond Kronecker, Schönhage-Strassen & Nussbaumer",
    "authors": [
      {
        "name": "Joppe W.  Bos",
        "email": "renes@nxp",
