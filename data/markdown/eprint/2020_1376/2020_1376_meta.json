  "debug_data_path": "debug_data/2020_1376",
  "eprint": {
    "title": "Stronger bounds on the cost of computing Groebner bases for HFE systems",
    "authors": [
      {
        "name": "Elisa Gorla",
        "email": "gorla@unine",
        "affiliation": ""
      },
      {
        "name": "Daniela Mueller",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Christophe Petit",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "We give upper bounds for the solving degree and the last fall degree of the polynomial system associated to the HFE (Hidden Field Equations) cryptosystem. Our bounds improve the known bounds for this type of systems. We also present new results on the connection between the solving degree and the last fall degree and prove that, in some cases, the solving degree is independent of coordinate changes.",
    "keywords": [
      "multivariate cryptography",
      "Groebner bases",
      "HFE",
      "(fake) Weil descent",
      "last fall degree",
      "solving degree"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Published elsewhere. Journal of Symbolic Computation",
    "last_updated": "2020-11-10",
    "license": "CC BY",
    "related_papers": []
  }
