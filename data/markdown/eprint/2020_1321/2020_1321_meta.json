  "debug_data_path": "debug_data/2020_1321",
  "eprint": {
    "title": "Provably Quantum-Secure Tweakable Block Ciphers",
    "authors": [
      {
        "name": "Akinori Hosoyamada",
        "email": "bh@hco",
        "affiliation": ""
      },
      {
        "name": "Tetsu Iwata",
        "email": "akinori@nagoya-u",
        "affiliation": ""
      }
    ],
    "abstract": "Recent results on quantum cryptanalysis show that some symmetric key schemes can be broken in polynomial time even if they are proven to be secure in the classical setting.\nLiskov, Rivest, and Wagner showed that secure tweakable block ciphers can be constructed from secure block ciphers in the classical setting.\nHowever, Kaplan et al.~showed that their scheme can be broken by polynomial time quantum superposition attacks, even if underlying block ciphers are quantum-secure.\nSince then, it remains open if there exists a mode of block ciphers to build quantum-secure tweakable block ciphers.\nThis paper settles the problem in the reduction-based provable security paradigm.\nWe show the first design of\nquantum-secure tweakable block ciphers based on quantum-secure block ciphers,\nand present a provable security bound.\nOur construction is simple, and when instantiated with a quantum-secure $n$-bit block cipher, it is secure against attacks that query arbitrary quantum superpositions of plaintexts and tweaks up to $O(2^{n/6})$ quantum queries.\nOur security proofs use the compressed oracle technique introduced by Zhandry.\nMore precisely, we use an alternative formalization of the technique introduced by Hosoyamada and Iwata.",
    "keywords": [
      "Provable security",
      "Quantum security",
      "Tweakable block cipher",
      "Compressed oracle technique"
    ],
    "category": "Secret-key cryptography",
    "publication_info": "Published by the IACR in FSE 2022",
    "last_updated": "2021-03-12",
    "license": "CC BY",
    "related_papers": []
  }
