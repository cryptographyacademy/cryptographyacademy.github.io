  "eprint": {
    "title": "The Measure-and-Reprogram Technique 2.0: Multi-Round Fiat-Shamir and More",
    "authors": [
      {
        "name": "Jelle Don",
        "email": "don@cwi",
        "affiliation": ""
      },
      {
        "name": "Serge Fehr",
        "email": "fehr@cwi",
        "affiliation": ""
      },
