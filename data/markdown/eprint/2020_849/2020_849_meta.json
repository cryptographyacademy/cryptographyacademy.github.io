  "eprint": {
    "title": "Surveying global verifiability",
    "authors": [
      {
        "name": "Ben Smyth",
        "email": "research@bensmyth",
        "affiliation": ""
      }
    ],
    "abstract": "We explore global verifiability; discovering that voting systems vulnerable to attack\ncan be proven to satisfy that security notion, whereas many secure systems cannot.\nWe conclude that current definitions are unsuitable for the analysis of voting systems, fuelling the exploration\nfor a suitable definition.",
    "keywords": [
      "voting",
      "verifiability",
      "provable security"
    ],
    "category": "Foundations",
    "publication_info": "Published elsewhere. Information Processing Letters",
    "last_updated": "2020-07-12",
