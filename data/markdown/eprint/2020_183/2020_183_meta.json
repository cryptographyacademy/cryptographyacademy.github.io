  "eprint": {
    "title": "A note on secure multiparty computation via higher residue symbols",
    "authors": [
      {
        "name": "Ignacio Cascudo",
        "email": "reto@math",
        "affiliation": ""
      },
      {
        "name": "Reto Schnyder",
