  "eprint": {
    "title": "An Instruction Set Extension to Support Software-Based Masking",
    "authors": [
      {
        "name": "Si Gao",
        "email": "groszschaedl@uni",
        "affiliation": ""
      },
      {
        "name": "Johann Großschädl",
        "email": "",
        "affiliation": ""
      },
      {
