  "eprint": {
    "title": "Bypassing Isolated Execution on RISC-V with Fault Injection",
    "authors": [
      {
        "name": "Shoei Nashimoto",
        "email": "shoei@bx",
        "affiliation": ""
      },
      {
        "name": "Daisuke Suzuki",
        "email": "",
