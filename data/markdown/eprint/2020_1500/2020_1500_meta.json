  "eprint": {
    "title": "Oblivious Transfer is in MiniQCrypt",
    "authors": [
      {
        "name": "Alex B.  Grilo",
        "email": "abgrilo@gmail",
        "affiliation": ""
      },
      {
        "name": "Huijia Lin",
