  "eprint": {
    "title": "Deterministic Wallets in a Quantum World",
    "authors": [
      {
        "name": "Nabil Alkeilani Alkadri",
        "email": "alkadri@cispa",
        "affiliation": ""
      },
      {
        "name": "Poulami Das",
        "email": "das@cispa",
        "affiliation": ""
      },
      {
        "name": "Andreas Erwig",
        "email": "erwig@tu-darmstadt",
        "affiliation": ""
      },
      {
        "name": "Sebastian Faust",
        "email": "faust@tu-darmstadt",
        "affiliation": ""
      },
      {
        "name": "Juliane Krämer",
        "email": "kraemer@ur",
