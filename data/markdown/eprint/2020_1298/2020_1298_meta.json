  "eprint": {
    "title": "Is Real-time Phishing Eliminated with FIDO? Social Engineering Downgrade Attacks against FIDO Protocols",
    "authors": [
      {
        "name": "Enis Ulqinaku",
        "email": "abdou@scs",
        "affiliation": ""
