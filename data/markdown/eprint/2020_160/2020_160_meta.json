  "eprint": {
    "title": "Solving Some Affine Equations over Finite Fields",
    "authors": [
      {
        "name": "Sihem Mesnager",
        "email": "smesnager@univ-paris8",
        "affiliation": ""
      },
      {
        "name": "Kwang Ho Kim",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Jong Hyok Choe",
        "email": "",
        "affiliation": ""
      },
      {
        "name": "Dok Nam Lee",
        "email": "",
        "affiliation": ""
      }
    ],
    "abstract": "Let $l$ and $k$ be two integers such that $l|k$. Define\n$T_l^k(X):=X+X^{p^l}+\\cdots+X^{p^{l(k/l-2)}}+X^{p^{l(k/l-1)}}$ and\n$S_l^k(X):=X-X^{p^l}+\\cdots+(-1)^{(k/l-1)}X^{p^{l(k/l-1)}}$, where\n$p$ is any prime.\n\nThis paper gives explicit representations of all solutions in\n$\\GF{p^n}$ to the affine equations $T_l^{k}(X)=a$ and\n$S_l^{k}(X)=a$, $a\\in \\GF{p^n}$. For the case $p=2$ that was solved\nvery recently in \\cite{MKCL2019}, the result of this paper reveals\nanother solution.",
    "keywords": [
      "Affine equation",
      "Finite field",
      "Zeros of a polynomial",
      "Linearized polynomial"
    ],
    "category": "Foundations",
    "publication_info": "Preprint. MINOR revision.",
    "last_updated": "2020-02-13",
    "license": "CC BY",
    "related_papers": []
  }
