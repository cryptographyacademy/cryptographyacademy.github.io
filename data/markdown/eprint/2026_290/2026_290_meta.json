  "eprint": {
    "title": "Improved Cryptanalysis of HFERP",
    "authors": [
      {
        "name": "Max Cartor",
        "email": "mcartor01@bellarmine",
        "affiliation": ""
      },
      {
        "name": "Ryann Cartor",
        "email": "edurcartor@clemson",
        "affiliation": ""
      },
      {
        "name": "Hiroki Furue",
        "email": "furue@ntt",
        "affiliation": ""
      },
      {
        "name": "Daniel Smith-Tone",
        "email": "smith@nist",
        "affiliation": ""
      }
    ],
    "abstract": "In this paper we introduce a new attack on the multivariate\r\nencryption scheme HFERP, a big field scheme including an extra variable\r\nset, additional equations of the UOV or Rainbow shape as well as addi-\r\ntional random polynomials. Our attack brings several parameter sets well\r\nbelow their claimed security levels. The attack combines novel methods\r\napplicable to multivariate schemes with multiple equation types with in-\r\nsights from the Simple Attack that broke Rainbow in early 2022, though\r\ninterestingly the technique is applied in an orthogonal way. In addition to\r\nthis attack, we apply support minors techniques on a MinRank instance\r\ndrawing coefficients from the big field, which was effective against other\r\nmultivariate big field schemes. This work demonstrates that there exist\r\npreviously unknown impacts of the above works well beyond the scope\r\nin which they were derived.",
    "keywords": [
      "Multivariate Cryptography",
      "HFERP",
      "Cryptanalysis",
      "MinRank",
      "Simple Attack"
    ],
    "category": "Attacks and cryptanalysis",
    "publication_info": "Published by the IACR in PKC 2024",
    "last_updated": "2026-02-18",
    "license": "CC0",
    "related_papers": []
  }
