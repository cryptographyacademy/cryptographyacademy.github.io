  "eprint": {
    "title": "Gadget-Based iNTRU Lattice Trapdoors",
    "authors": [
      {
        "name": "Nicholas Genise",
        "email": "genise@sri",
        "affiliation": ""
      },
      {
        "name": "Baiyu Li",
        "email": "combaiyu@cs",
        "affiliation": ""
      }
    ],
    "abstract": "We present two new related families of lattice trapdoors based on the inhomogeneous NTRU problem\n(iNTRU) defined in Genise et. al (ASIACRYPT 2019).\nOur constructions are ``gadget-based'' and offer compact secret keys and\npreimages and compatibility with existing,\nefficient preimage sampling algorithms. Our trapdoors\ncan be used as a fundamental building block in lattice-based schemes\nrelying lattice trapdoors. In addition,\nwe implemented our trapdoors using the PALISADE library.",
    "keywords": [
      "digital signatures",
      "lattice trapdoor",
      "iNTRU"
    ],
    "category": "Public-key cryptography",
    "publication_info": "Published elsewhere. Minor revision. Indocrypt 2020",
    "last_updated": "2020-10-29",
    "license": "CC BY",
    "related_papers": []
  }
